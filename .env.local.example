# Copy this file to .env.local and replace every placeholder.
# Never commit .env.local.

TIME_ARCHIVE_DATABASE_NAME=time_archive
TIME_ARCHIVE_DATABASE_USERNAME=time_archive
TIME_ARCHIVE_DATABASE_PASSWORD=replace-with-random-local-database-password

# These MinIO and S3-compatible application credentials must match locally.
TIME_ARCHIVE_MINIO_ROOT_USER=replace-with-local-minio-user
TIME_ARCHIVE_MINIO_ROOT_PASSWORD=replace-with-random-local-minio-password
TIME_ARCHIVE_STORAGE_S3_ACCESS_KEY=replace-with-local-minio-user
TIME_ARCHIVE_STORAGE_S3_SECRET_KEY=replace-with-random-local-minio-password

TIME_ARCHIVE_RATE_LIMIT_KEY_SALT=replace-with-random-local-hmac-key
TIME_ARCHIVE_PAYMENT_FAKE_ENABLED=true
TIME_ARCHIVE_RATE_LIMIT_REGISTRATION_LIMIT=100
TIME_ARCHIVE_INITIAL_ADMIN_EMAILS=admin@time-archive.local
